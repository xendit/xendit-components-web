{
  "name": "xendit-components-web",
  "version": "0.0.12",
  "description": "Xendit frontend payment components SDK",
  "type": "module",
  "author": "Xendit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xendit/xendit-components-web"
  },
  "keywords": [
    "xendit",
    "payment",
    "payments",
    "payment processing",
    "credit cards",
    "checkout",
    "components"
  ],
  "files": [
    "./sdk/dist/index.umd.js",
    "./sdk/dist/index.umd.js.map",
    "./sdk/dist/index.esm.js",
    "./sdk/dist/index.esm.js.map",
    "./sdk/dist/index.d.ts",
    "./README.md",
    "./CHANGELOG.md"
  ],
  "types": "./sdk/dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./sdk/dist/index.d.ts",
      "default": "./sdk/dist/index.esm.js"
    },
    "require": {
      "types": "./sdk/dist/index.d.ts",
      "default": "./sdk/dist/index.umd.js"
    }
  },
  "scripts": {
    "dev": "./build.ts dev",
    "build": "./build.ts prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:debug": "vitest run --printConsoleTrace=true --silent=false",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --fix --ext .ts,.tsx",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --check --write",
    "prepare": "husky"
  },
  "dependencies": {
    "card-validator": "^10.0.4",
    "classnames": "^2.5.1",
    "libphonenumber-js": "^1.12.38",
    "preact": "^10.28.4",
    "qrcode": "^1.5.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "^1.9.1",
    "@eslint/js": "^9.39.3",
    "@microsoft/api-extractor": "^7.57.6",
    "@preact/preset-vite": "^2.10.3",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.11.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "mime-types": "^3.0.2",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-import-css": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.28.1"
}
